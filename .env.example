# ===== 웨일허니콤 환경변수 (.env.local로 복사해서 사용) =====

# 실시간 주가 (선택) — 없으면 야후/스투크 무료 소스 사용
# https://finnhub.io 무료 가입 후 발급
FINNHUB_API_KEY=

# Web Push (npm run push:keys 실행 시 자동 생성됨)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hikim942@naver.com

# 이메일 알림 (Gmail) — Google 계정 > 보안 > 2단계 인증 > 앱 비밀번호 발급
# 미설정 시 워처가 콘솔 로그로 대체 출력
GMAIL_USER=
GMAIL_APP_PASSWORD=

# 공시 워처 폴링 간격 (분)
WATCH_INTERVAL_MIN=5
